modules = ["php-8.2", "web", "nodejs-20", "bash", "php-8.4"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash f1-pickem/start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
